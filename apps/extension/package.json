{
  "name": "openbox",
  "displayName": "OpenBox",
  "description": "OpenBox Extension",
  "version": "0.1.0",
  "publisher": "openbox",
  "icon": "media/icon.png",
  "license": "MIT",
  "homepage": "https://openbox.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenBox-AI/openbox-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/OpenBox-AI/openbox-sdk/issues"
  },
  "keywords": [
    "ai",
    "ai-governance",
    "guardrails",
    "policy",
    "opa",
    "approvals",
    "hitl",
    "agent-trace",
    "cursor",
    "claude-code"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:openbox.onboard",
    "onView:openbox.approvals",
    "onView:openbox.history",
    "onView:openbox.profile",
    "onView:openbox.debugControls",
    "onCommand:openbox.setApiKey",
    "onCommand:openbox.openDashboard",
    "onCommand:openbox.openWalkthrough",
    "onCommand:openbox.reboot"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "icons": {
      "openbox-logo": {
        "description": "OpenBox logo",
        "default": {
          "fontPath": "media/openbox-icons.woff2",
          "fontCharacter": "\\F101"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openbox",
          "title": "OpenBox",
          "icon": "$(openbox-logo)"
        }
      ]
    },
    "views": {
      "openbox": [
        {
          "id": "openbox.onboard",
          "name": "Welcome",
          "when": "openbox.needsKey"
        },
        {
          "id": "openbox.approvals",
          "name": "Pending Approvals",
          "when": "!openbox.needsKey"
        },
        {
          "id": "openbox.history",
          "name": "History",
          "when": "!openbox.needsKey"
        },
        {
          "id": "openbox.profile",
          "name": "Profile",
          "when": "!openbox.needsKey"
        },
        {
          "id": "openbox.debugControls",
          "name": "Debug",
          "when": "openbox.debug"
        }
      ]
    },
    "commands": [
      {
        "command": "openbox.approve",
        "title": "Approve",
        "icon": "$(check)"
      },
      {
        "command": "openbox.reject",
        "title": "Reject",
        "icon": "$(x)"
      },
      {
        "command": "openbox.refresh",
        "title": "Refresh Approvals",
        "icon": "$(refresh)"
      },
      {
        "command": "openbox.openDetail",
        "title": "Open Approval Detail"
      },
      {
        "command": "openbox.copyDetail",
        "title": "Copy Approval Detail"
      },
      {
        "command": "openbox.search",
        "title": "OpenBox: Search Approvals",
        "icon": "$(search)"
      },
      {
        "command": "openbox.filter",
        "title": "OpenBox: Filter Approvals",
        "icon": "$(filter)"
      },
      {
        "command": "openbox.filterTier",
        "title": "OpenBox: Filter by Tier"
      },
      {
        "command": "openbox.filterType",
        "title": "OpenBox: Filter by Activity Type"
      },
      {
        "command": "openbox.filterTeam",
        "title": "OpenBox: Filter by Team"
      },
      {
        "command": "openbox.filterOwner",
        "title": "OpenBox: Filter by Owner"
      },
      {
        "command": "openbox.toggleSort",
        "title": "OpenBox: Toggle Sort Order",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "openbox.clearFilters",
        "title": "OpenBox: Clear Filters",
        "icon": "$(clear-all)"
      },
      {
        "command": "openbox.loadMore",
        "title": "Load More Approvals"
      },
      {
        "command": "openbox.history.refresh",
        "title": "Refresh History",
        "icon": "$(refresh)"
      },
      {
        "command": "openbox.history.search",
        "title": "OpenBox: Search History",
        "icon": "$(search)"
      },
      {
        "command": "openbox.history.filter",
        "title": "OpenBox: Filter History",
        "icon": "$(filter)"
      },
      {
        "command": "openbox.history.filterTier",
        "title": "OpenBox: Filter History by Tier"
      },
      {
        "command": "openbox.history.filterType",
        "title": "OpenBox: Filter History by Activity Type"
      },
      {
        "command": "openbox.history.filterTeam",
        "title": "OpenBox: Filter History by Team"
      },
      {
        "command": "openbox.history.filterOwner",
        "title": "OpenBox: Filter History by Owner"
      },
      {
        "command": "openbox.history.toggleSort",
        "title": "OpenBox: Toggle History Sort Order",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "openbox.history.clearFilters",
        "title": "OpenBox: Clear History Filters",
        "icon": "$(clear-all)"
      },
      {
        "command": "openbox.history.setStatus",
        "title": "OpenBox: Set History Status",
        "icon": "$(history)"
      },
      {
        "command": "openbox.history.setDateRange",
        "title": "OpenBox: Set History Date Range",
        "icon": "$(calendar)"
      },
      {
        "command": "openbox.history.loadMore",
        "title": "Load More History"
      },
      {
        "command": "openbox.setApiKey",
        "title": "OpenBox: Set API Key…",
        "icon": "$(key)"
      },
      {
        "command": "openbox.openDashboard",
        "title": "OpenBox: Open Dashboard",
        "icon": "$(link-external)"
      },
      {
        "command": "openbox.clearCredentials",
        "title": "OpenBox: Clear All Credentials…"
      },
      {
        "command": "openbox.signOut",
        "title": "OpenBox: Sign Out",
        "icon": "$(sign-out)"
      },
      {
        "command": "openbox.reboot",
        "title": "OpenBox: Reload",
        "icon": "$(refresh)"
      },
      {
        "command": "openbox.openWalkthrough",
        "title": "OpenBox: Open Getting Started"
      },
      {
        "command": "openbox.switchEnvironment",
        "title": "OpenBox: Switch Environment (dev only)",
        "icon": "$(globe)",
        "enablement": "openbox.debug || openbox.devMode"
      },
      {
        "command": "openbox.showDebugInfo",
        "title": "OpenBox: Show Debug Info",
        "icon": "$(info)",
        "enablement": "openbox.debug"
      },
      {
        "command": "openbox.toggleMockAuth",
        "title": "OpenBox: Toggle Mock Auth",
        "icon": "$(beaker)",
        "enablement": "openbox.debug"
      },
      {
        "command": "openbox.seedMockData",
        "title": "OpenBox: Seed Mock Data",
        "icon": "$(add)",
        "enablement": "openbox.debug"
      },
      {
        "command": "openbox.resetMockData",
        "title": "OpenBox: Reset Mock Data",
        "icon": "$(debug-restart)",
        "enablement": "openbox.debug"
      }
    ],
    "configuration": {
      "title": "OpenBox",
      "properties": {
        "openbox.environment": {
          "type": "string",
          "enum": [
            "production",
            "staging",
            "local"
          ],
          "default": "production",
          "description": "[Dev only] Which OpenBox environment the extension talks to. End users should leave this on 'production'. The Switch Environment command is only visible when the extension is running in development mode (Run Extension target). Each env has its own token namespace in ~/.openbox/tokens, so logging in via the CLI to staging won't clobber prod credentials."
        },
        "openbox.mockAuth": {
          "type": "boolean",
          "default": false,
          "description": "Run the extension against a built-in fixture set (no API key, no backend). Useful for first-run demos, contributor onboarding, and exercising the UI without minting credentials. When true, the api-key load is skipped, the approvals panel is fed from local fixtures, and approve/reject decisions are kept in-memory only."
        },
        "openbox.tabObserver.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Observe non-keystroke buffer mutations (Tab autocomplete accept, Cmd-K, Composer multi-file edits) and log them to the 'OpenBox: Tab Observer' output channel. Cursor does not expose hooks for these surfaces, so the observer classifies changes heuristically (size + idle timing). Off by default; turn on to inspect what the observer would report before piping to OpenBox."
        },
        "openbox.tabObserver.outputLog": {
          "type": "boolean",
          "default": true,
          "description": "When tabObserver.enabled is true, also write each classified change to the 'OpenBox: Tab Observer' output channel. Set false to suppress that visibility; the in-process classification still runs. Has no effect when tabObserver.enabled is false."
        },
        "openbox.tabObserver.emitAgentTrace": {
          "type": "boolean",
          "default": false,
          "description": "When true (and openbox.tabObserver.enabled is also true), every classified non-keystroke insert appends a TraceRecord to ~/.openbox/log/agent-trace.jsonl following the cursor/agent-trace v0.1.0 RFC. Records carry contributor type (human/ai), file path, line range, and SHA-256 content hash. Lets git tools / canvas / audit pipelines that ingest the open Agent Trace format pick up OpenBox's attribution data without bespoke wiring. Has no effect when tabObserver.enabled is false."
        },
        "openbox.agentId": {
          "type": "string",
          "default": "",
          "description": "OpenBox agent ID to evaluate file writes / AI inserts / file ops against. When unset, all active gates (preWriteGate.active, tabObserver.active, fileOpGate.enabled) become no-ops; without an agent ID there is no policy context. The runtime key for this agent must be present in ~/.openbox/agent-keys (populated by `openbox api-key rotate <agentId>`) or as the OPENBOX_API_KEY environment variable visible to the extension host."
        },
        "openbox.preWriteGate.active": {
          "type": "boolean",
          "default": false,
          "description": "When true, every save calls check_governance(file_write) for the configured agent. `allow` lets the save proceed; `require_approval` blocks the save with a modal until decided; `deny` cancels the save with a notification. Network deadline is 4s under VS Code's ~5s save timeout; on timeout or network failure the gate fails open unless openbox.failClosed is set. Requires openbox.agentId."
        },
        "openbox.tabObserver.active": {
          "type": "boolean",
          "default": false,
          "description": "When true (and openbox.tabObserver.enabled is also true), classified non-keystroke inserts are evaluated via check_governance(file_write). Denied inserts get reverted via WorkspaceEdit and a notification is shown. UX is jarring (the insert briefly appears, then disappears); use sparingly and prefer preWriteGate.active for at-save enforcement when possible. Requires openbox.agentId."
        },
        "openbox.fileOpGate.enabled": {
          "type": "boolean",
          "default": false,
          "description": "When true, intercepts onWillCreateFiles / onWillDeleteFiles / onWillRenameFiles and evaluates each via check_governance. Catches Composer multi-file creates and AI-driven file ops that don't route through the agent's Write tool. Requires openbox.agentId."
        },
        "openbox.failClosed": {
          "type": "boolean",
          "default": false,
          "description": "When true, all active gates fail closed (cancel the action) on network errors / timeouts contacting core. Default false (fail open) so a transient network blip doesn't block the user; flip on for high-trust environments where blocking on uncertainty is preferred."
        },
        "openbox.strictSourceFilter": {
          "type": "boolean",
          "default": false,
          "description": "When true, hide approval rows whose source can't be resolved (no module or gen_ai.system on the row's first span). By default these unresolvable rows pass through so no real approval is hidden by accident; the backend strips spans from its pending-list endpoint, so most live rows fall into the unresolvable bucket. Enable for strict per-host isolation, accepting that some legitimate rows may be hidden until the backend persists metadata.source server-side."
        }
      }
    },
    "viewsWelcome": [
      {
        "view": "openbox.onboard",
        "contents": "Welcome to OpenBox.\n\nPaste an org API key to start reviewing agent approvals. Create one in the dashboard under Organization → API Keys.\n\n[Set API Key](command:openbox.setApiKey)\n[Open Dashboard](command:openbox.openDashboard)"
      },
      {
        "view": "openbox.approvals",
        "contents": "Loading…",
        "when": "!openbox.needsKey && openbox.loading"
      },
      {
        "view": "openbox.approvals",
        "contents": "No pending approvals\n\nYou're all caught up.\n[Refresh](command:openbox.refresh)",
        "when": "!openbox.needsKey && !openbox.loading && !openbox.hasFilters"
      },
      {
        "view": "openbox.approvals",
        "contents": "No matches\n\nTry clearing your filters.\n\n[Clear filters](command:openbox.clearFilters)",
        "when": "!openbox.needsKey && !openbox.loading && openbox.hasFilters"
      },
      {
        "view": "openbox.history",
        "contents": "Loading…",
        "when": "!openbox.needsKey && openbox.history.loading"
      },
      {
        "view": "openbox.history",
        "contents": "Nothing here yet\n\nDecided approvals will show up here.",
        "when": "!openbox.needsKey && !openbox.history.loading && !openbox.history.hasFilters"
      },
      {
        "view": "openbox.history",
        "contents": "No matches\n\nTry clearing your filters.\n\n[Clear filters](command:openbox.history.clearFilters)",
        "when": "!openbox.needsKey && !openbox.history.loading && openbox.history.hasFilters"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "openbox.switchEnvironment",
          "when": "openbox.debug || openbox.devMode"
        },
        {
          "command": "openbox.showDebugInfo",
          "when": "openbox.debug"
        },
        {
          "command": "openbox.toggleMockAuth",
          "when": "openbox.debug"
        },
        {
          "command": "openbox.seedMockData",
          "when": "openbox.debug"
        },
        {
          "command": "openbox.resetMockData",
          "when": "openbox.debug"
        },
        {
          "command": "openbox.openDetail",
          "when": "false"
        },
        {
          "command": "openbox.copyDetail",
          "when": "false"
        },
        {
          "command": "openbox.loadMore",
          "when": "false"
        },
        {
          "command": "openbox.history.loadMore",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "openbox.search",
          "when": "view == openbox.approvals",
          "group": "navigation@1"
        },
        {
          "command": "openbox.filter",
          "when": "view == openbox.approvals",
          "group": "navigation@2"
        },
        {
          "command": "openbox.toggleSort",
          "when": "view == openbox.approvals",
          "group": "navigation@3"
        },
        {
          "command": "openbox.clearFilters",
          "when": "view == openbox.approvals && openbox.hasFilters",
          "group": "navigation@4"
        },
        {
          "command": "openbox.refresh",
          "when": "view == openbox.approvals",
          "group": "navigation@5"
        },
        {
          "command": "openbox.history.search",
          "when": "view == openbox.history",
          "group": "navigation@1"
        },
        {
          "command": "openbox.history.setDateRange",
          "when": "view == openbox.history",
          "group": "navigation@2"
        },
        {
          "command": "openbox.history.filter",
          "when": "view == openbox.history",
          "group": "navigation@4"
        },
        {
          "command": "openbox.history.toggleSort",
          "when": "view == openbox.history",
          "group": "navigation@5"
        },
        {
          "command": "openbox.history.clearFilters",
          "when": "view == openbox.history && openbox.history.hasFilters",
          "group": "navigation@6"
        },
        {
          "command": "openbox.history.refresh",
          "when": "view == openbox.history",
          "group": "navigation@7"
        },
        {
          "command": "openbox.openDashboard",
          "when": "view == openbox.profile",
          "group": "navigation@1"
        },
        {
          "command": "openbox.setApiKey",
          "when": "view == openbox.profile",
          "group": "navigation@2"
        },
        {
          "command": "openbox.signOut",
          "when": "view == openbox.profile",
          "group": "navigation@3"
        },
        {
          "command": "openbox.switchEnvironment",
          "when": "view == openbox.debugControls",
          "group": "navigation@1"
        },
        {
          "command": "openbox.toggleMockAuth",
          "when": "view == openbox.debugControls",
          "group": "navigation@2"
        },
        {
          "command": "openbox.seedMockData",
          "when": "view == openbox.debugControls",
          "group": "navigation@3"
        },
        {
          "command": "openbox.resetMockData",
          "when": "view == openbox.debugControls",
          "group": "navigation@4"
        },
        {
          "command": "openbox.showDebugInfo",
          "when": "view == openbox.debugControls",
          "group": "navigation@5"
        },
        {
          "command": "openbox.reboot",
          "when": "view == openbox.debugControls",
          "group": "navigation@6"
        }
      ],
      "view/item/context": [
        {
          "command": "openbox.approve",
          "when": "viewItem == approval",
          "group": "inline"
        },
        {
          "command": "openbox.reject",
          "when": "viewItem == approval",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify --define:process.env.OPENBOX_DEBUG_BUILD=\\\"false\\\"",
    "build:dev": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --define:process.env.OPENBOX_DEBUG_BUILD=\\\"true\\\"",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch --define:process.env.OPENBOX_DEBUG_BUILD=\\\"true\\\"",
    "package": "npx @vscode/vsce package --no-dependencies",
    "package:dev": "npm run build:dev && npx @vscode/vsce package --no-dependencies",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.24.0",
    "openbox-sdk": "file:../..",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "socket.io-client": "^4.8.3"
  }
}
