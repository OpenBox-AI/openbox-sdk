{
  "name": "openbox-sdk",
  "version": "0.1.0",
  "description": "OpenBox AI governance SDK - TypeScript. Generated from a TypeSpec source of truth shared with the rust/, go/, python/ language SDKs in this repo.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openbox": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./core-client": {
      "types": "./dist/core-client/index.d.ts",
      "import": "./dist/core-client/index.js"
    },
    "./env": {
      "types": "./dist/env/index.d.ts",
      "import": "./dist/env/index.js"
    },
    "./os-paths": {
      "types": "./dist/env/os-paths.d.ts",
      "import": "./dist/env/os-paths.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./runtime/claude-code": {
      "types": "./dist/runtime/claude-code/index.d.ts",
      "import": "./dist/runtime/claude-code/index.js"
    },
    "./runtime/cursor": {
      "types": "./dist/runtime/cursor/index.d.ts",
      "import": "./dist/runtime/cursor/index.js"
    },
    "./runtime/mcp": {
      "types": "./dist/runtime/mcp/index.d.ts",
      "import": "./dist/runtime/mcp/index.js"
    }
  },
  "files": [
    "dist",
    "skill"
  ],
  "workspaces": [
    "codegen/typespec-libs/*",
    "codegen/emitters/typespec-emitter-typescript",
    "apps/*"
  ],
  "scripts": {
    "build:codegen": "npm run build -w typespec-env -w typespec-cli -w typespec-workflow -w typespec-emitter-typescript",
    "build:bundle": "tsup",
    "build": "npm run build:codegen && npm run specs:compile && npm run generate:types && npm run build:bundle",
    "prepare": "npm run build",
    "check:publish": "bash scripts/check-publish-safety.sh",
    "prepublishOnly": "npm run build && npm run check:publish",
    "clean": "rm -rf dist dist-pack codegen/**/dist codegen/**/tsconfig.tsbuildinfo ts/src/**/generated specs/generated apps/extension/dist apps/extension/openbox-*.vsix",
    "clean:generated": "rm -rf ts/src/**/generated specs/generated",
    "check:generated-drift": "npm run specs:compile && npm run generate:types && git diff --exit-code -- ts/src/**/generated specs/generated || (echo 'Generated files drift detected. Re-run npm run specs:all and commit the result.'; exit 1)",
    "lint": "eslint ts/src",
    "format": "prettier --write ts/src",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:watch": "vitest watch",
    "generate:types:backend": "openapi-typescript specs/generated/openapi3/OpenboxBackend.json -o ts/src/types/generated/backend.ts",
    "generate:types:core": "openapi-typescript specs/generated/openapi3/OpenboxCore.json    -o ts/src/types/generated/core.ts",
    "generate:types": "npm run generate:types:backend && npm run generate:types:core",
    "specs:compile": "tsp compile specs/typespec",
    "specs:all": "npm run build:codegen && npm run specs:compile && npm run generate:types",
    "specs:watch": "tsp compile specs/typespec --watch",
    "lint:generated-banners": "node scripts/check-generated-banners.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^14.0.0",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "playwright": "^1.50.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@typespec/compiler": "^1.11.0",
    "@typespec/http": "^1.11.0",
    "@typespec/json-schema": "^1.11.0",
    "@typespec/openapi": "^1.11.0",
    "@typespec/openapi3": "^1.11.0",
    "@typespec/rest": "^0.81.0",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "openapi-typescript": "^7.13.0",
    "ts-morph": "^28.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.2"
  }
}
