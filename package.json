{
  "name": "@openbox-ai/openbox-sdk",
  "version": "0.1.1",
  "description": "OpenBox AI governance SDK for TypeScript, generated from the TypeSpec contract source in this monorepo.",
  "keywords": [
    "openbox",
    "governance",
    "ai-agents",
    "guardrails",
    "policies",
    "approvals",
    "trust",
    "claude-code",
    "cursor",
    "mcp"
  ],
  "license": "MIT",
  "author": "OpenBox AI",
  "homepage": "https://github.com/OpenBox-AI/openbox-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenBox-AI/openbox-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/OpenBox-AI/openbox-sdk/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openbox": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./core-client": {
      "types": "./dist/core-client/index.d.ts",
      "import": "./dist/core-client/index.js"
    },
    "./env": {
      "types": "./dist/env/index.d.ts",
      "import": "./dist/env/index.js"
    },
    "./approvals": {
      "types": "./dist/approvals/index.d.ts",
      "import": "./dist/approvals/index.js"
    },
    "./anthropic-agent-sdk": {
      "types": "./dist/anthropic-agent-sdk/index.d.ts",
      "import": "./dist/anthropic-agent-sdk/index.js"
    },
    "./client-factory": {
      "types": "./dist/client-factory/index.d.ts",
      "import": "./dist/client-factory/index.js"
    },
    "./file-tokens": {
      "types": "./dist/file-tokens/index.d.ts",
      "import": "./dist/file-tokens/index.js"
    },
    "./polling": {
      "types": "./dist/polling/index.d.ts",
      "import": "./dist/polling/index.js"
    },
    "./os-paths": {
      "types": "./dist/env/os-paths.d.ts",
      "import": "./dist/env/os-paths.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./validators": {
      "types": "./dist/validators/index.d.ts",
      "import": "./dist/validators/index.js"
    },
    "./test-utils": {
      "types": "./dist/test-utils/index.d.ts",
      "import": "./dist/test-utils/index.js"
    },
    "./maturity": {
      "types": "./dist/maturity/index.d.ts",
      "import": "./dist/maturity/index.js"
    },
    "./runtime/claude-code": {
      "types": "./dist/runtime/claude-code/index.d.ts",
      "import": "./dist/runtime/claude-code/index.js"
    },
    "./runtime/codex": {
      "types": "./dist/runtime/codex/index.d.ts",
      "import": "./dist/runtime/codex/index.js"
    },
    "./runtime/cursor": {
      "types": "./dist/runtime/cursor/index.d.ts",
      "import": "./dist/runtime/cursor/index.js"
    },
    "./runtime/mcp": {
      "types": "./dist/runtime/mcp/index.d.ts",
      "import": "./dist/runtime/mcp/index.js"
    },
    "./runtime/n8n": {
      "types": "./dist/runtime/n8n/index.d.ts",
      "import": "./dist/runtime/n8n/index.js"
    },
    "./governance": {
      "types": "./dist/governance/index.d.ts",
      "import": "./dist/governance/index.js"
    },
    "./agent-trace": {
      "types": "./dist/agent-trace/index.d.ts",
      "import": "./dist/agent-trace/index.js"
    },
    "./logging": {
      "types": "./dist/logging/index.d.ts",
      "import": "./dist/logging/index.js"
    },
    "./session": {
      "types": "./dist/session/index.d.ts",
      "import": "./dist/session/index.js"
    },
    "./install": {
      "types": "./dist/install/index.d.ts",
      "import": "./dist/install/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./copilotkit": {
      "types": "./dist/copilotkit/index.d.ts",
      "import": "./dist/copilotkit/index.js"
    },
    "./copilotkit/react": {
      "types": "./dist/copilotkit/react.d.ts",
      "import": "./dist/copilotkit/react.js"
    },
    "./openai-agents-sdk": {
      "types": "./dist/openai-agents-sdk/index.d.ts",
      "import": "./dist/openai-agents-sdk/index.js"
    }
  },
  "files": [
    "dist",
    "skill"
  ],
  "workspaces": [
    "codegen/typespec-libs/*",
    "codegen/emitters/typespec-emitter",
    "apps/*"
  ],
  "scripts": {
    "build:codegen": "npm run build -w typespec-env -w typespec-cli -w typespec-workflow -w typespec-emitter",
    "build:bundle": "tsup && node --experimental-strip-types scripts/sync-runtime-assets.ts",
    "build": "npm run generate:sdks && npm run build:bundle",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist dist-pack codegen/**/dist codegen/**/tsconfig.tsbuildinfo specs/generated apps/extension/dist apps/extension/openbox-*.vsix && npm run clean:generated",
    "clean:generated": "find ts/src -path '*/generated/*.ts' -type f -delete && find ts/src -path '*/generated/*.d.ts' -type f -delete && rm -rf specs/generated python/openbox_sdk/generated codegen/method-names.json codegen/method-permissions.json codegen/fixtures/provider-capabilities.json codegen/fixtures/sdk-manifests.json",
    "check:generated-drift": "node --experimental-strip-types scripts/check-generated-drift.ts",
    "lint": "eslint ts/src",
    "format": "prettier --write ts/src",
    "test": "npm run test:unit && npm run test:contract && npm run test:hook-integration",
    "test:unit": "vitest run --project unit",
    "test:contract": "vitest run --project contract",
    "test:hook-integration": "vitest run --project hook-integration",
    "generate:sdks": "npm run build:codegen && npm run specs:compile",
    "check:sdks": "npm run generate:sdks && npm run lint && npx tsc --noEmit && OPENBOX_CLI=./scripts/openbox-cli-dev.mjs npm run test && cd python && uv run --locked --extra dev ruff check . && uv run --locked --extra dev mypy openbox_sdk tests && uv run --locked --extra dev pytest && uv build",
    "ci:local": "npm run check:sdks && OPENBOX_CLI=./scripts/openbox-cli-dev.mjs npx vitest run --coverage --project unit --project contract --project hook-integration --coverage.reporter=lcov && NODE_OPTIONS=--max-old-space-size=4096 npm run build && npm run check:generated-drift && npm run lint:generated-banners && npx --yes @stoplight/spectral-cli lint specs/generated/openapi3/*.json && npm audit --audit-level=high && npm run audit:security",
    "specs:compile": "tsp compile specs/typespec",
    "specs:all": "npm run generate:sdks",
    "specs:watch": "tsp compile specs/typespec --watch",
    "lint:generated-banners": "node --experimental-strip-types scripts/check-generated-banners.ts",
    "audit:security": "node scripts/security-audit.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^14.0.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@ag-ui/client": ">=0.0.53",
    "@anthropic-ai/claude-agent-sdk": ">=0.3.181",
    "@openai/agents": ">=0.11.7",
    "@copilotkit/react-core": ">=1.56.0",
    "@copilotkit/runtime": ">=1.56.0",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "@openai/agents": {
      "optional": true
    },
    "@ag-ui/client": {
      "optional": true
    },
    "@copilotkit/runtime": {
      "optional": true
    },
    "@copilotkit/react-core": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.181",
    "@openai/agents": "^0.11.7",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.16",
    "@typespec/compiler": "^1.11.0",
    "@typespec/http": "^1.11.0",
    "@typespec/json-schema": "^1.11.0",
    "@typespec/openapi": "^1.11.0",
    "@typespec/openapi3": "^1.11.0",
    "@typespec/rest": "^0.81.0",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "openapi-typescript": "^7.13.0",
    "react": "^19.2.7",
    "ts-morph": "^28.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.2",
    "ws": "^8.21.0"
  },
  "overrides": {
    "@redocly/openapi-core": "1.34.7",
    "esbuild": "^0.28.1",
    "engine.io-client": {
      "ws": "^8.21.0"
    },
    "js-yaml": "^4.2.0",
    "tsx": "^4.22.4"
  }
}
