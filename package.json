{
  "name": "openbox-sdk",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./core-client": {
      "types": "./dist/core-client.d.ts",
      "import": "./dist/core-client.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "import": "./dist/env.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "ts/*",
    "codegen/typespec-libs/*",
    "codegen/emitters/ts"
  ],
  "scripts": {
    "build:workspaces": "npm run build -w @openbox/types && npm run build -w @openbox/env && npm run build -w @openbox/client && npm run build -w @openbox/core-client && npm run build -w @openbox/cli",
    "build:bundle": "tsup",
    "build": "npm run build:workspaces && npm run build:bundle",
    "prepare": "npm run build",
    "check:publish": "bash scripts/check-publish-safety.sh",
    "prepublishOnly": "npm run build && npm run check:publish",
    "clean": "rm -rf ts/*/dist ts/*/tsconfig.tsbuildinfo dist dist-pack",
    "lint": "eslint ts/*/src/",
    "format": "prettier --write ts/*/src/",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:e2e": "vitest run --project e2e",
    "test:watch": "vitest watch",
    "generate:types:backend": "openapi-typescript specs/generated/openapi3/OpenboxBackend.json -o ts/types/src/generated/backend.ts",
    "generate:types:core": "openapi-typescript specs/generated/openapi3/OpenboxCore.json    -o ts/types/src/generated/core.ts",
    "generate:types": "npm run generate:types:backend && npm run generate:types:core",
    "specs:libs": "npm run build -w @openbox/typespec-env -w @openbox/typespec-cli -w @openbox/typespec-workflow -w @openbox/typespec-emitter-ts",
    "specs:compile": "npm run specs:libs && tsp compile specs/typespec",
    "specs:all": "npm run specs:compile && npm run generate:types",
    "specs:watch": "tsp compile specs/typespec --watch",
    "lint:generated-banners": "node scripts/check-generated-banners.mjs"
  },
  "license": "MIT",
  "devDependencies": {
    "@typespec/compiler": "^1.11.0",
    "@typespec/http": "^1.11.0",
    "@typespec/json-schema": "^1.11.0",
    "@typespec/openapi": "^1.11.0",
    "@typespec/openapi3": "^1.11.0",
    "@typespec/rest": "^0.81.0",
    "@vitest/coverage-v8": "^4.1.5",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "openapi-typescript": "^7.13.0",
    "ts-morph": "^28.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.2"
  }
}
