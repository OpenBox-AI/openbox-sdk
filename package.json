    "openbox",
    "governance",
    "ai-agents",
    "guardrails",
    "policies",
    "approvals",
    "trust",
    "claude-code",
    "cursor",
    "mcp"
  ],
  "license": "MIT",
  "author": "OpenBox AI",
  "homepage": "https://github.com/OpenBox-AI/openbox-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OpenBox-AI/openbox-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/OpenBox-AI/openbox-sdk/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
