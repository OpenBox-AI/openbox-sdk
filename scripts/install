#!/usr/bin/env sh
# OpenBox CLI installer.
#
#   curl -fsSL https://raw.githubusercontent.com/OpenBox-AI/openbox-sdk/main/scripts/install | sh
#
# Private-repo (until the repo flips public):
#
#   # via gh CLI (uses your authenticated session for both fetch + clone):
#   gh api -H "Accept: application/vnd.github.raw" \
#     repos/OpenBox-AI/openbox-sdk/contents/scripts/install | sh
#
#   # via raw token (CI / scripted; needs `repo` scope):
#   curl -fsSL -H "Authorization: Bearer $GITHUB_TOKEN" \
#     https://raw.githubusercontent.com/OpenBox-AI/openbox-sdk/main/scripts/install | sh
#
# Clones the source, installs deps (bun if present, else npm), builds,
# and symlinks the CLI into ~/.openbox/bin/openbox. Build-from-source
# because there's no published package and no signed binary release.
#
# Env overrides:
#   OPENBOX_VERSION       git ref (default: main)
#   OPENBOX_INSTALL_DIR   alternate root (default: ~/.openbox)
#   OPENBOX_LOCAL_SOURCE  point at a local openbox-sdk checkout (skips
#                         git clone; useful for testing uncommitted
#                         changes end-to-end before pushing)
#   OPENBOX_NO_PATH       skip writing the PATH entry to your shell rc
#   OPENBOX_NO_RELOAD     skip reloading your shell at the end
#   NO_COLOR              disable color
#   NO_ANIM               disable spinner animation (status lines still print)

set -eu

REPO_URL="https://github.com/OpenBox-AI/openbox-sdk"
INSTALL_ROOT="${OPENBOX_INSTALL_DIR:-${HOME}/.openbox}"
SRC_DIR="${INSTALL_ROOT}/src"
BIN_DIR="${INSTALL_ROOT}/bin"
VERSION="${OPENBOX_VERSION:-main}"

# tput-based color palette; no-op on dumb terminals / NO_COLOR.

if [ -z "${NO_COLOR:-}" ] && [ -t 1 ] && command -v tput >/dev/null 2>&1; then
  C_RESET="$(tput sgr0     2>/dev/null || printf '')"
  C_BOLD="$(tput bold      2>/dev/null || printf '')"
  C_DIM="$(tput dim        2>/dev/null || printf '')"
  C_RED="$(tput setaf 1    2>/dev/null || printf '')"
  C_GREEN="$(tput setaf 2  2>/dev/null || printf '')"
  C_YELLOW="$(tput setaf 3 2>/dev/null || printf '')"
  C_CYAN="$(tput setaf 6   2>/dev/null || printf '')"
  C_GREY="$(tput setaf 8   2>/dev/null || tput setaf 7 2>/dev/null || printf '')"
  C_CYAN_BR="$(printf '\033[96m')"
  C_WHITE_BR="$(printf '\033[97m')"
  HIDE_CURSOR="$(tput civis 2>/dev/null || printf '')"
  SHOW_CURSOR="$(tput cnorm 2>/dev/null || printf '')"
else
  C_RESET=""; C_BOLD=""; C_DIM=""; C_RED=""; C_GREEN=""; C_YELLOW=""
  C_CYAN=""; C_GREY=""; C_CYAN_BR=""; C_WHITE_BR=""
  HIDE_CURSOR=""; SHOW_CURSOR=""
fi

GLYPH_OK="✓"
GLYPH_ERR="x"
GLYPH_WARN="!"

# Animate when stdout is a TTY and `sleep 0.01` works.
if [ -z "${NO_ANIM:-}" ] && [ -t 1 ] && sleep 0.01 2>/dev/null; then
  ANIMATE=1
else
  ANIMATE=0
fi

# Restore cursor if the user Ctrl-C's mid-animation.
trap 'printf "%s" "$SHOW_CURSOR"; exit 130' INT TERM

# ---------------------------------------------------------------------------
# Spinner: 10 Braille frames + 10-color palindrome pulse (cyan → near-
# white → cyan). One color per frame so the pulse stays locked to the
# rotation.
# ---------------------------------------------------------------------------

SPINNER_FRAMES="⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏"

if [ -z "${NO_COLOR:-}" ] && [ -t 1 ]; then
  P1="$(printf '\033[38;5;51m')"
  P2="$(printf '\033[38;5;87m')"
  P3="$(printf '\033[38;5;123m')"
  P4="$(printf '\033[38;5;159m')"
  P5="$(printf '\033[38;5;195m')"
  PULSE_COLORS="$P1 $P2 $P3 $P4 $P5 $P5 $P4 $P3 $P2 $P1"
else
  PULSE_COLORS="                    "  # ten empty slots
fi

# ms → human-friendly elapsed counter (1.4s / 12s / 1m 04s).
fmt_elapsed_ms() {
  ms=$1
  if [ "$ms" -lt 10000 ]; then
    s=$((ms / 1000))
    t=$(( (ms % 1000) / 100 ))
    printf '%d.%ds' "$s" "$t"
  elif [ "$ms" -lt 60000 ]; then
    printf '%ds' $((ms / 1000))
  else
    m=$((ms / 60000))
    s=$(( (ms % 60000) / 1000 ))
    printf '%dm %02ds' "$m" "$s"
  fi
}

# Millisecond-precision wall clock. macOS `date` lacks `+%N`, so we
# prefer perl/python and fall back to second-precision.
now_ms() {
  if command -v perl >/dev/null 2>&1; then
    perl -MTime::HiRes=time -e 'printf "%d\n", time()*1000'
  elif command -v python3 >/dev/null 2>&1; then
    python3 -c 'import time; print(int(time.time()*1000))'
  else
    echo $(( $(date +%s) * 1000 ))
  fi
}

# Last non-empty line of $1, stripped of ANSI + control chars,
# truncated to 76 cols so it fits the 2-space indent on 80-col tty.
tail_logline() {
  [ -s "$1" ] || { printf ''; return; }
  awk '
    {
      gsub(/\033\[[0-9;]*[a-zA-Z]/, "")
      gsub(/\r/, "")
      gsub(/[[:cntrl:]]/, "")
    }
    /[^[:space:]]/ { last = $0 }
    END { print last }
  ' "$1" 2>/dev/null | cut -c 1-76
}

spin() {
  pid="$1"; msg="$2"; logfile="${3:-}"
  start_ms="$(now_ms)"

  printf '%s' "$HIDE_CURSOR"

  i=0
  spinner_total=10
  pulse_total=4
  drawn=0

  while kill -0 "$pid" 2>/dev/null; do
    i=$(( (i % spinner_total) + 1 ))

    # shellcheck disable=SC2086
    set -- $SPINNER_FRAMES
    eval "frame=\${$i}"

    pulse_idx=$(( ((i - 1) / 2) % pulse_total + 1 ))
    # shellcheck disable=SC2086
    set -- $PULSE_COLORS
    eval "color=\${$pulse_idx}"

    elapsed_ms=$(( $(now_ms) - start_ms ))
    elapsed_str="$(fmt_elapsed_ms "$elapsed_ms")"

    last_line=""
    if [ -n "$logfile" ]; then
      last_line="$(tail_logline "$logfile")"
    fi

    if [ "$drawn" = "1" ]; then
      printf '\033[1A'  # cursor up to line 1
    fi
    # Line 1: spinner + desc + elapsed.
    printf '\r\033[K  %s%s%s %s%s%s  %s%s%s\n' \
      "$color" "$frame" "$C_RESET" \
      "$C_DIM" "$msg" "$C_RESET" \
      "$C_GREY" "$elapsed_str" "$C_RESET"
    # Line 2: latest log line (dimmed, indented past the spinner glyph).
    printf '\r\033[K    %s%s%s' "$C_GREY" "$last_line" "$C_RESET"
    drawn=1

    sleep 0.08
  done

  if [ "$drawn" = "1" ]; then
    printf '\r\033[K\033[1A\r\033[K'
  fi
  printf '%s' "$SHOW_CURSOR"
}

# run "<desc>" -- <cmd...>: log to tempfile, animate, dump on failure.
run() {
  desc="$1"; shift
  [ "${1:-}" = "--" ] && shift
  log="$(mktemp)"
  start_ms="$(now_ms)"

  if [ "$ANIMATE" = "1" ]; then
    "$@" >"$log" 2>&1 &
    pid=$!
    spin "$pid" "$desc" "$log"
    wait "$pid"
    status=$?
  else
    # Non-TTY: print one line + a 5s "still working" tick so a piped
    # log shows progress.
    printf '  > %s\n' "$desc"
    (
      while sleep 5; do
        ms=$(( $(now_ms) - start_ms ))
        printf '    … still working (%s)\n' "$(fmt_elapsed_ms "$ms")"
      done
    ) &
    tick_pid=$!
    if "$@" >"$log" 2>&1; then status=0; else status=$?; fi
    kill "$tick_pid" 2>/dev/null || true
    wait "$tick_pid" 2>/dev/null || true
  fi

  total_ms=$(( $(now_ms) - start_ms ))
  elapsed_str="$(fmt_elapsed_ms "$total_ms")"

  if [ "$status" -eq 0 ]; then
    printf '\r\033[K  %s%s%s %s  %s%s%s\n' \
      "$C_GREEN" "$GLYPH_OK" "$C_RESET" "$desc" \
      "$C_GREY" "$elapsed_str" "$C_RESET"
    rm -f "$log"
    return 0
  fi

  printf '\r\033[K  %s%s%s %s\n\n' "$C_RED" "$GLYPH_ERR" "$C_RESET" "$desc" >&2
  printf '%s%s%s\n' "$C_DIM" "$(cat "$log")" "$C_RESET" >&2
  rm -f "$log"
  exit 1
}

note()  { printf '  %s>%s %s\n' "$C_DIM" "$C_RESET" "$*"; }
fatal() { printf '  %s%s%s %s\n' "$C_RED" "$GLYPH_ERR" "$C_RESET" "$*" >&2; exit 1; }

print_banner() {
  printf '\n  %s%s┃%s %sopenbox-sdk%s %s· %s%s\n' \
    "$C_BOLD" "$C_CYAN" "$C_RESET" \
    "$C_BOLD" "$C_RESET" \
    "$C_DIM" "$VERSION" "$C_RESET"
  printf '  %s┃%s %sbuild-from-source%s\n\n' \
    "$C_CYAN" "$C_RESET" "$C_GREY" "$C_RESET"
}

print_env_overrides() {
  shown=0
  maybe_header() {
    if [ "$shown" = "0" ]; then
      printf '  %senv overrides%s\n' "$C_BOLD" "$C_RESET"
      shown=1
    fi
  }
  for v in OPENBOX_VERSION OPENBOX_INSTALL_DIR OPENBOX_LOCAL_SOURCE OPENBOX_NO_PATH OPENBOX_NO_RELOAD NO_COLOR NO_ANIM; do
    eval "val=\${$v:-}"
    if [ -n "$val" ]; then
      maybe_header
      printf '    %s%-22s%s %s\n' "$C_DIM" "$v" "$C_RESET" "$val"
    fi
  done
  for v in OPENBOX_GITHUB_TOKEN GITHUB_TOKEN GH_TOKEN; do
    eval "val=\${$v:-}"
    if [ -n "$val" ]; then
      maybe_header
      printf '    %s%-22s%s %s<set>%s\n' "$C_DIM" "$v" "$C_RESET" "$C_DIM" "$C_RESET"
    fi
  done
  if [ "$shown" = "1" ]; then printf '\n'; fi
}

print_banner
print_env_overrides

# ---------------------------------------------------------------------------
# Prerequisites
# ---------------------------------------------------------------------------

need() {
  command -v "$1" >/dev/null 2>&1 || fatal "missing: $1: $2"
}

need git  "install git via your OS package manager"
need node "install node 20+ from https://nodejs.org or nvm"

node_major="$(node -p 'process.versions.node.split(".")[0]')"
[ "$node_major" -ge 20 ] || fatal "node 20+ required (found $node_major); 'nvm install 20' fixes it"

if command -v bun >/dev/null 2>&1; then
  # bun for install (faster), npm for build (bun rewrites `npm run -w`
  # in a way that recursively re-invokes the root build).
  # `--ignore-scripts` skips the `prepare` lifecycle since we run the
  # build explicitly below.
  pm_name="bun"; pm_install="bun install --ignore-scripts"; pm_build="npm run build"
else
  pm_name="npm"; pm_install="npm ci --ignore-scripts";      pm_build="npm run build"
fi

# ---------------------------------------------------------------------------
# Source tree
# ---------------------------------------------------------------------------

mkdir -p "$INSTALL_ROOT" "$BIN_DIR"

# Pick a clone URL. While the repo is private, prefer an explicit
# token in env, then ask `gh` for one. Falls through to the plain
# https URL (which works if `gh auth setup-git` ran or HTTPS creds
# are otherwise wired into git).
clone_url="$REPO_URL"
token="${OPENBOX_GITHUB_TOKEN:-${GITHUB_TOKEN:-${GH_TOKEN:-}}}"
if [ -z "$token" ] && command -v gh >/dev/null 2>&1; then
  token="$(gh auth token 2>/dev/null || true)"
fi
if [ -n "$token" ]; then
  clone_url="https://oauth2:${token}@github.com/OpenBox-AI/openbox-sdk"
fi

if [ -n "${OPENBOX_LOCAL_SOURCE:-}" ]; then
  [ -f "${OPENBOX_LOCAL_SOURCE}/package.json" ] || \
    fatal "OPENBOX_LOCAL_SOURCE=${OPENBOX_LOCAL_SOURCE} isn't an openbox-sdk checkout (no package.json)"
  SRC_DIR="$(cd "$OPENBOX_LOCAL_SOURCE" && pwd)"
  printf '  %s>%s using local source %s%s%s\n' \
    "$C_DIM" "$C_RESET" "$C_BOLD" "$SRC_DIR" "$C_RESET"
elif [ -d "$SRC_DIR/.git" ]; then
  run "fetch ${VERSION}"    -- git -C "$SRC_DIR" fetch --tags --quiet origin
  run "checkout ${VERSION}" -- git -C "$SRC_DIR" checkout --quiet "$VERSION"
  run "sync to origin"      -- sh -c "git -C \"$SRC_DIR\" reset --hard --quiet \"origin/$VERSION\" 2>/dev/null || git -C \"$SRC_DIR\" reset --hard --quiet \"$VERSION\""
elif [ -e "$SRC_DIR" ]; then
  fatal "$SRC_DIR exists but isn't a git checkout; remove it or set OPENBOX_INSTALL_DIR"
else
  run "clone openbox-sdk@${VERSION}" -- git clone --quiet --depth=1 --branch "$VERSION" "$clone_url" "$SRC_DIR"
fi

cd "$SRC_DIR"

# ---------------------------------------------------------------------------
# Install + build
# ---------------------------------------------------------------------------

run "install deps via $pm_name" -- sh -c "$pm_install"
run "build"                     -- sh -c "$pm_build"

cli_entry="$SRC_DIR/dist/cli/index.js"
[ -x "$cli_entry" ] || fatal "build did not produce $cli_entry"

# Install a wrapper script (not a symlink) so the CLI keeps working
# even if the source tree later moves or the dist path changes.
# Wrapper resolves dist via $OPENBOX_INSTALL_DIR > ~/.openbox/install-path
# > ~/.openbox/src at every invocation; see scripts/openbox-cli-wrapper.sh
# for the lookup contract.
target="$BIN_DIR/openbox"
rm -f "$target"
install -m 0755 "$SRC_DIR/scripts/openbox-cli-wrapper.sh" "$target"
# Default the install-path file to this checkout so the wrapper
# resolves correctly even before the user customizes anything.
printf '%s\n' "$SRC_DIR" > "$INSTALL_ROOT/install-path"
note "installed wrapper  ${C_BOLD}${target}${C_RESET}"

# ---------------------------------------------------------------------------
# Footer
# ---------------------------------------------------------------------------

case ":${PATH}:" in
  *":${BIN_DIR}:"*) on_path=1 ;;
  *)                on_path=0 ;;
esac

version_str="$("$target" --version 2>/dev/null || echo '(version unavailable)')"
printf '\n  %s%s installed%s  %s%s%s\n' \
  "$C_GREEN" "$GLYPH_OK" "$C_RESET" \
  "$C_DIM" "$version_str" "$C_RESET"

# ---------------------------------------------------------------------------
# Auto PATH wiring + shell reload.
#
# rustup/cargo pattern: keep PATH management in a separate env file
# (~/.openbox/env, ~/.openbox/env.fish) that the user's rc just
# sources. Future PATH changes rewrite the env file in place: the rc
# stays untouched after the first install. Re-runs of this installer
# detect the marker (`# openbox-sdk`) in the rc and don't double-write.
# ---------------------------------------------------------------------------

ENV_FILE_POSIX="${INSTALL_ROOT}/env"
ENV_FILE_FISH="${INSTALL_ROOT}/env.fish"
RC_MARKER="# openbox-sdk"

# Detect the right rc file. We pick the file the user's interactive
# shell actually loads:
#   zsh    → ~/.zshrc
#   bash macOS → ~/.bash_profile (Terminal.app launches login shells)
#   bash linux → ~/.bashrc
#   fish   → ~/.config/fish/config.fish
#   else   → ~/.profile
detect_rc() {
  case "${SHELL:-}" in
    */zsh)  printf '%s\n' "${HOME}/.zshrc" ;;
    */bash)
      if [ "$(uname -s)" = "Darwin" ]; then
        printf '%s\n' "${HOME}/.bash_profile"
      else
        printf '%s\n' "${HOME}/.bashrc"
      fi
      ;;
    */fish) printf '%s\n' "${HOME}/.config/fish/config.fish" ;;
    *)      printf '%s\n' "${HOME}/.profile" ;;
  esac
}

# Write/refresh the env file. Always runs, so OPENBOX_INSTALL_DIR
# overrides flow through on re-install without touching the rc.
write_env_file() {
  cat > "$ENV_FILE_POSIX" <<EOF
# Auto-generated by the openbox-sdk installer. Sourced by your shell rc.
# Re-running the installer rewrites this file; do not edit by hand.
case ":\${PATH}:" in
  *":${BIN_DIR}:"*) ;;
  *) export PATH="${BIN_DIR}:\${PATH}" ;;
esac
EOF
  cat > "$ENV_FILE_FISH" <<EOF
# Auto-generated by the openbox-sdk installer. Sourced by your config.fish.
if not contains "${BIN_DIR}" \$PATH
    fish_add_path "${BIN_DIR}"
end
EOF
}

# rc snippet that sources the env file (marker on its own line so
# detection / future removal is easy).
rc_snippet_posix() {
  printf '%s\n[ -f "%s" ] && . "%s"\n' \
    "$RC_MARKER" "$ENV_FILE_POSIX" "$ENV_FILE_POSIX"
}
rc_snippet_fish() {
  printf '%s\ntest -f "%s"; and source "%s"\n' \
    "$RC_MARKER" "$ENV_FILE_FISH" "$ENV_FILE_FISH"
}

if [ -z "${OPENBOX_NO_PATH:-}" ]; then
  write_env_file
  rc_file="$(detect_rc)"
  mkdir -p "$(dirname "$rc_file")"

  if [ -f "$rc_file" ] && grep -qF "$RC_MARKER" "$rc_file" 2>/dev/null; then
    printf '  %s%s%s rc already sources %s (%s)\n' \
      "$C_DIM" "$GLYPH_OK" "$C_RESET" "$ENV_FILE_POSIX" "$rc_file"
  else
    case "${SHELL:-}" in
      */fish) snippet="$(rc_snippet_fish)" ;;
      *)      snippet="$(rc_snippet_posix)" ;;
    esac
    {
      printf '\n'
      printf '%s\n' "$snippet"
    } >> "$rc_file"
    printf '  %s%s wired%s %s into %s\n' \
      "$C_GREEN" "$GLYPH_OK" "$C_RESET" \
      "$ENV_FILE_POSIX" "$rc_file"
  fi

  # Symlink into a system-PATH directory so non-interactive shells
  # (/bin/sh -c "..." from Claude Code hooks, cron, IDE extensions)
  # find `openbox`. The rc-sourced env file only covers interactive
  # shells; without this symlink, hooks fire before zshrc runs and
  # report "openbox: command not found".
  if [ -z "${OPENBOX_NO_SYMLINK:-}" ]; then
    sys_target=""
    for d in /opt/homebrew/bin /usr/local/bin; do
      if [ -d "$d" ] && [ -w "$d" ]; then
        sys_target="$d/openbox"
        break
      fi
    done
    if [ -n "$sys_target" ]; then
      ln -sf "$BIN_DIR/openbox" "$sys_target"
      printf '  %s%s symlinked%s %s -> %s\n' \
        "$C_GREEN" "$GLYPH_OK" "$C_RESET" "$sys_target" "$BIN_DIR/openbox"
    else
      printf '  %s%s no writable system-PATH dir found; non-interactive shells\n' \
        "$C_DIM" "$GLYPH_WARN"
      printf '  %s  may not find openbox. Run: sudo ln -sf %s /usr/local/bin/openbox%s\n' \
        "$C_DIM" "$BIN_DIR/openbox" "$C_RESET"
    fi
  fi
fi

printf '\n  %snext%s\n    %sopenbox auth set-api-key%s\n    %sopenbox install <extension|cursor|claude-code|mcp|skill>%s\n\n' \
  "$C_BOLD" "$C_RESET" \
  "$C_CYAN" "$C_RESET" \
  "$C_DIM"  "$C_RESET"

# Reload the shell so the new PATH takes effect now. Skipped when PATH
# already has BIN_DIR (no-op reload) or OPENBOX_NO_RELOAD is set.
if [ "$on_path" = "0" ] && [ -z "${OPENBOX_NO_RELOAD:-}" ] && [ -n "${SHELL:-}" ]; then
  if [ -t 0 ]; then
    exec "$SHELL"
  elif [ -r /dev/tty ]; then
    exec < /dev/tty "$SHELL"
  fi
fi
