# vitest coverage report; regenerated on every `npm run test:coverage`.
/coverage
# tsup or tsc occasionally emits .d.ts next to source when composite
# mode resolves the openbox-sdk sub-path mappings into the workspace
# src/. Don't commit.
ts/*/src/**/*.d.ts
ts/*/src/**/*.d.ts.map
# TypeSpec emitter outputs. Reproducible from `npx tsp compile specs/typespec`.
# These stay untracked verification output; committed generated code lives under
# `ts/src/**/generated/` and `dist/`.
/specs/generated/openapi3/
/specs/generated/json-schema/
# Local auth state; never commit.
.tokens
.env
.env.local
.infisical.json
