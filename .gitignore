node_modules
dist
apps/*/dist
codegen/**/dist
dist-pack
*.tsbuildinfo
__pycache__/
*.py[cod]
# vitest coverage report; regenerated by explicit coverage runs.
/coverage
.tmp/
karate/target/
/target/
# tsup or tsc occasionally emits .d.ts next to source when composite
# mode resolves the openbox-sdk sub-path mappings into the workspace
# src/. Don't commit.
ts/*/src/**/*.d.ts
ts/*/src/**/*.d.ts.map
# TypeSpec emitter outputs. Reproducible from `npx tsp compile specs/typespec`.
# These stay untracked verification output; committed generated code lives under
# `ts/src/**/generated/`. Package artifacts are built into `dist/` only for
# local packaging and publish.
/specs/generated/openapi3/
/specs/generated/json-schema/
# Local auth state; never commit.
.tokens
.openbox/
.env
.env.local
.infisical.json

.github-account
.gh-account
.gh-user

# Project-local hook runtime output. Hook config/install files can be
# intentionally committed, but per-session state and logs are local runtime data.
.openbox/claude-code/sessions/
.openbox/claude-code/log/
.openbox/codex/.env
.openbox/codex/sessions/
.openbox/codex/log/
.openbox/cursor/.env
.openbox/cursor/sessions/
.openbox/cursor/log/
