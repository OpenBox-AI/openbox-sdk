{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@openbox-ai/openbox-sdk/anthropic-agent-sdk": [
        "ts/src/anthropic-agent-sdk/index.ts"
      ],
      "@openbox-ai/openbox-sdk/openai-agents-sdk": [
        "ts/src/openai-agents-sdk/index.ts"
      ],
      "@openbox-ai/openbox-sdk/runtime/codex": [
        "ts/src/runtime/codex/index.ts"
      ]
    }
  },
  "include": ["ts/src/**/*", "codegen/**/src/**/*", "tests/**/*"],
  "exclude": [
    "tests/fixtures/verify-samples/**/*",
    "tests/e2e-extension/**/*"
  ]
}
