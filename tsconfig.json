{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["ts/src/**/*", "codegen/**/src/**/*", "tests/**/*"],
  "exclude": [
    "tests/fixtures/verify-samples/**/*",
    "tests/e2e-extension/**/*"
  ]
}
