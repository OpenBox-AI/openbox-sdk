{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "types": ["@wdio/globals/types", "@wdio/mocha-framework", "node"],
    "noEmit": true
  },
  "include": ["wdio.conf.ts", "live-bootstrap.ts", "suites/**/*.ts"]
}
