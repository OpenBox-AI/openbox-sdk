# Public hostname for the OpenBox POC app surface. The hosted n8n editor,
# chat webhook, and Slack Event URL live under /ob/n8n/.
N8N_HOST=app.ipsum.lat

# OpenBox endpoint/key. For a real public demo, point at the deployed Core and
# use a real runtime API key from your OpenBox dashboard/secret store.
OPENBOX_API_URL=https://core.ipsum.lat/ob
OPENBOX_API_KEY=obx_live_replace_me

# n8n database. Rotate these before hosting.
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace_with_long_random_postgres_password
POSTGRES_DB=n8n

# n8n internal secrets. Must be stable across restarts, and must be real random
# values before public hosting.
N8N_ENCRYPTION_KEY=replace_with_32_plus_random_chars
N8N_USER_MANAGEMENT_JWT_SECRET=replace_with_32_plus_random_chars
N8N_LOG_LEVEL=info

# LLM runtime. Hosted ipsum.lat uses OpenRouter so the VPS does not need to
# pull or run a local model image.
OPENROUTER_API_KEY=replace_with_infisical_OPENROUTER_API_KEY
OPENROUTER_MODEL=liquid/lfm-2.5-1.2b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Slack app credentials are stored in Infisical for the hosted demo and applied
# to the n8n Slack API credential. This channel ID restricts Slack output and
# the Slack trigger to one channel.
SLACK_CHANNEL_ID=
SLACK_TEST_CHANNEL_NAME=openbox-triage-bot

# Optional HubSpot Free CRM output. Disabled by default. Create a HubSpot
# private app token in n8n credentials, then enable this branch.
HUBSPOT_CRM_ENABLED=false
