# Optional. Leave unset for local dev — the `seed` service in this
# compose provisions a default agent in your local OpenBox stack and
# writes the runtime API key into a shared volume that n8n picks up on
# startup. Set this to override (e.g. when pointing at staging/prod).
# OPENBOX_API_KEY=obx_live_replace_me

# Core endpoint. Defaults to the local docker stack over the shared
# network. Use https://core.openbox.ai for production.
OPENBOX_API_URL=http://openbox-core-server:8086

# OpenRouter is the hosted/default LLM path. Leave the key empty for local
# Ollama-only demos.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=liquid/lfm-2.5-1.2b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama runs as a container on the same docker network. The model is
# auto-pulled on first start by the `ollama-pull` init service. Smaller
# models = faster pull / smaller cache. Examples: tinyllama (~640MB),
# llama3.2:1b (~1.3GB), llama3.2:3b (~2GB).
OLLAMA_MODEL=tinyllama

# Optional: override the postgres credentials used for n8n's own state.
# These are local-only; nothing here is shared with OpenBox.
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n
POSTGRES_DB=n8n

# Optional HubSpot Free CRM branch. Create a HubSpot private app credential in
# n8n, then enable this.
HUBSPOT_CRM_ENABLED=false

# Optional Slack branch. Create a Slack bot token/signing-secret credential in
# n8n and set this to the target channel ID, for example C0123456789.
SLACK_CHANNEL_ID=

# n8n internal secrets. The defaults are fine for local; rotate if you
# expose this beyond localhost.
N8N_ENCRYPTION_KEY=example-only-encryption-key
N8N_USER_MANAGEMENT_JWT_SECRET=example-only-jwt-secret
N8N_LOG_LEVEL=info
